# @brief Generates Coyote bitstreams, both full (including the static and shell layer),
# as well as partial, including only the shell (.bin files) for dynamic run-time reconfiguration
# Additionally, generates ILA config files to be used in Vivado HW manager.

if {[catch {
    
########################################################################################################

# Config
source "${CMAKE_BINARY_DIR}/base.tcl"

########################################################################################################
# GENERATE BITSTREAMS
########################################################################################################
puts "[color $clr_flow "** Starting shell bitstream generation ..."]"
puts "[color $clr_flow "**"]"

file mkdir "$bit_dir"

if {$cfg(en_pr) eq 0} {
    open_checkpoint "$dcp_dir/shell_routed.dcp"
    if {$cfg(build_static) eq 1} {
        # Coyote top; including the shell and the static layer
        if {$cfg(fpga_arch) eq "ultrascale_plus"} {
            write_bitstream -force -no_partial_bitfile "$bit_dir/cyt_top.bit"
            write_debug_probes -no_partial_ltxfile -force "$bit_dir/cyt_top.ltx"
        } elseif {$cfg(fpga_arch) eq "versal"} {
            write_device_image -force -no_partial_pdifile "$bit_dir/cyt_top.pdi"
            write_debug_probes -force -no_partial_ltxfile "$bit_dir/cyt_top.ltx"

            # On Versal devices, partial reconfiguration can be done through PCIe/QDMA
            # However, to do so, boot_device must be set to PCIe in the BIF file
            # As of 2025.1, it's not possible to configure the boot_device to PCIe directly through Vivado TCL commands
            # Therefore, a utility script 'fix_bif.py' is provided to modify the BIF file accordingly
            # Once the modified BIF file is created, bootgen is used to generate the "new" PDI
            exec rm "$bit_dir/cyt_top.pdi"
            exec python fix_bif.py "$bit_dir/cyt_top.bif"
            exec bootgen -arch versal -image "$bit_dir/cyt_top.bif" -w -o "$bit_dir/cyt_top.pdi"
        } else {
            puts "ERROR: Unsupported FPGA architecture: $cfg(fpga_arch)"
            exit 1
        }
    } else {
        if {$cfg(fpga_arch) eq "ultrascale_plus"} {
            # Partial shell bitstream, without static layer (used for dynamic reconfiguration) 
            # Note, the CMake validation enforces that en_shell_pblock = 1 in the shell flow mode
            if {$cfg(en_shell_pblock) eq 1} {
                write_bitstream -force -bin_file -no_binary_bitfile -cell "inst_shell" "$bit_dir/shell_top.bit"
                write_debug_probes -force -quiet -cell "inst_shell" "$bit_dir/shell_top.ltx"   
            } else {
                puts "INFO: Skipping generation of partial shell bitstream, since shell reconfiguration is disabled (EN_SHELL_RECONFIG=0)"
            }

            # Coyote top: static layer + shell (used for initial loading of the bitstream)
            write_bitstream -force -no_partial_bitfile "$bit_dir/cyt_top.bit"
            write_debug_probes -no_partial_ltxfile -force "$bit_dir/cyt_top.ltx"
        } elseif {$cfg(fpga_arch) eq "versal"} {
            # Note, the CMake validation enforces that en_shell_pblock = 1 in the shell flow mode
            if {$cfg(en_shell_pblock) eq 1} {
                # Partial shell bitstream, without static layer (used for dynamic reconfiguration) 
                write_device_image -force -cell "inst_shell" "$bit_dir/shell_top.pdi"
                write_debug_probes -force -quiet -cell "inst_shell" "$bit_dir/shell_top.ltx"
            } else {
                puts "INFO: Skipping generation of partial shell image, since shell reconfiguration is disabled (EN_SHELL_RECONFIG=0)"
            }

            # Coyote top: static layer + shell (used for initial loading of the bitstream)
            write_device_image -force -no_partial_pdifile "$bit_dir/cyt_top.pdi"
            write_debug_probes -force -no_partial_ltxfile "$bit_dir/cyt_top.ltx"

            # Add boot_device property and regenerate bitstream
            exec rm "$bit_dir/cyt_top.pdi"
            exec python fix_bif.py "$bit_dir/cyt_top.bif"
            exec bootgen -arch versal -image "$bit_dir/cyt_top.bif" -w -o "$bit_dir/cyt_top.pdi"
        } else {
            puts "ERROR: Unsupported FPGA architecture: $cfg(fpga_arch)"
            exit 1
        }
    }
    
    close_project
} else {    
    for {set i 0}  {$i < $cfg(n_config)} {incr i} {
        open_checkpoint "$dcp_dir/config_$i/shell_routed_c$i.dcp"
        file mkdir "$bit_dir/config_$i"
        for {set j 0}  {$j < $cfg(n_reg)} {incr j} {
            if {$cfg(fpga_arch) eq "ultrascale_plus"} {
                write_bitstream -force -no_binary_bitfile -bin_file -cell "inst_shell/inst_dynamic/inst_user_wrapper_$j" "$bit_dir/config_$i/vfpga_c$i\_$j.bit"
                write_debug_probes -quiet -force -cell "inst_shell/inst_dynamic/inst_user_wrapper_$j" "$bit_dir/config_$i/vfpga_c$i\_$j.ltx"
            } elseif {$cfg(fpga_arch) eq "versal"} {
                write_device_image -force -cell "inst_shell/inst_dynamic/inst_user_wrapper_$j" "$bit_dir/config_$i/vfpga_c$i\_$j.pdi"
                write_debug_probes -force -quiet -cell "inst_shell/inst_dynamic/inst_user_wrapper_$j" "$bit_dir/config_$i/vfpga_c$i\_$j.ltx"
            } else {
                puts "ERROR: Unsupported FPGA architecture: $cfg(fpga_arch)"
                exit 1
            }
        }
        close_project
    }

    if {$cfg(build_shell) eq 1} {
        if {$cfg(fpga_arch) eq "ultrascale_plus"} {
            open_checkpoint "$dcp_dir/shell_recombined.dcp"

            # Partial shell bitstream, for shell reconfiguration (without static layer)
            write_bitstream -force -bin_file -no_binary_bitfile -cell "inst_shell" "$bit_dir/shell_top.bit"
            write_debug_probes -force -quiet -cell "inst_shell" "$bit_dir/shell_top.ltx"

            # For completness sake, Coyote top including shell and static layer (user for initial loading of the bitstream)
            write_bitstream -force -no_partial_bitfile "$bit_dir/cyt_top.bit"
            write_debug_probes -no_partial_ltxfile -force "$bit_dir/cyt_top.ltx"
        } elseif {$cfg(fpga_arch) eq "versal"} {
            open_checkpoint "$dcp_dir/shell_routed.dcp"

            # Do not generate shell PDI, as shell reconfiguration is disabled
            # when vFPGA reconfiguration is enabled (nested reconfiguration isn't supported on Versal devices)

            # Coyote top including shell and static layer (user for initial loading of the bitstream)
            write_device_image -force -no_partial_pdifile "$bit_dir/cyt_top.pdi"
            write_debug_probes -force -no_partial_ltxfile "$bit_dir/cyt_top.ltx"

            # Add boot_device property and regenerate bitstream
            exec rm "$bit_dir/cyt_top.pdi"
            exec python fix_bif.py "$bit_dir/cyt_top.bif"
            exec bootgen -arch versal -image "$bit_dir/cyt_top.bif" -w -o "$bit_dir/cyt_top.pdi"
        } else {
            puts "ERROR: Unsupported FPGA architecture: $cfg(fpga_arch)"
            exit 1
        }
        close_project
    }
}

########################################################################################################
# BITSTREAM GENERATION COMPLETED
########################################################################################################
puts ""
puts "[color $clr_cmplt "**"]"
puts "[color $clr_cmplt "** Shell bitstreams generated"]"
puts "[color $clr_cmplt "**"]"
puts "" 

########################################################################################################

} errorstring]} {
    puts "[color $clr_error "** CERR: $errorstring"]"
    puts "[color $clr_error "**"]"
    exit 1
}

exit 0