# Helper script for Versal bitgen, adding boot_device { pcie } to the top-level .bif file

import sys

def insert_boot_device(path):
    with open(path, 'r') as f:
        lines = f.readlines()

    out = []
    inserted = False
    found_master_section = False

    # Iterate through file, until bitstream_master section is found
    for line in lines:
        out.append(line)

        # Detect start of bitstream_master section
        if 'bitstream_master:' in line:
            found_master_section = True
        
        # Insert after the id line inside bitstream_master
        if found_master_section and not inserted and 'id =' in line:
            out.append(' boot_device { pcie }\n')
            inserted = True

    with open(path, 'w') as f:
        f.writelines(out)

if __name__ == '__main__':
    if len(sys.argv) != 2:
        print('Usage: python add_boot_device.py <file>')
        sys.exit(1)

    insert_boot_device(sys.argv[1])
